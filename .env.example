NODE_ENV=development
PORT=3004
# Supabase PROD (kmepxyervpeujwvgdqtm) — password from Dashboard → Settings → Database (URL-encode special chars)
DATABASE_URL=postgresql://postgres:REPLACE_WITH_SUPABASE_DB_PASSWORD@db.kmepxyervpeujwvgdqtm.supabase.co:5432/postgres
DATABASE_SCHEMA=fakturownia-ksef-invoices
N8N_API_KEY=replace-with-n8n-to-backend-secret
ADMIN_API_KEY=replace-with-admin-secret
PANEL_API_KEY=replace-with-panel-secret
PANEL_ORIGIN=http://localhost:3000
BITRIX24_WEBHOOK_URL=https://evapremium.bitrix24.pl/rest/1/replace-with-webhook-token/
BITRIX24_PORTAL_URL=https://evapremium.bitrix24.pl/
FAKTUROWNIA_BASE_URL=https://example.fakturownia.pl/
FAKTUROWNIA_API_TOKEN=replace-with-fakturownia-token
FAKTUROWNIA_REQUEST_TIMEOUT_MS=30000
FAKTUROWNIA_KSEF_STATUS_POLL_TIMEOUT_MS=60000
FAKTUROWNIA_KSEF_STATUS_POLL_INTERVAL_MS=5000
# Custom invoice numbering ({n}/{MM}.{YYYY}); bootstrap for current month only
FAKTUROWNIA_INVOICE_NUMBER_BOOTSTRAP_MONTH=2026-05
FAKTUROWNIA_INVOICE_NUMBER_BOOTSTRAP_FULL=39
FAKTUROWNIA_INVOICE_NUMBER_BOOTSTRAP_ADVANCE=28
FAKTUROWNIA_INVOICE_NUMBER_BOOTSTRAP_FINAL=35
N8N_INVOICE_EMAIL_WEBHOOK_URL=https://n8n.example.com/webhook/invoice-email
N8N_INVOICE_EMAIL_WEBHOOK_SECRET=replace-with-n8n-invoice-email-webhook-secret
N8N_INVOICE_EMAIL_WEBHOOK_TIMEOUT_MS=30000

# Live tests (manual/ops only — never enable in production without explicit intent)
LIVE_TEST_MODE=false
LIVE_TEST_CONFIRM=false
ENABLE_EXTERNAL_SIDE_EFFECTS=false
ALLOW_TEST_DEAL_CREATION=false
TEST_DEAL_PREFIX=[TEST]
ALLOW_BULK_LIVE_TESTS=false
ALLOW_DELETE_OR_CANCEL=false
# Controlled single POST to /invoice-processes/bitrix-trigger (default blocked)
LIVE_TEST_ALLOW_BACKEND_TRIGGER_EXECUTION=false
# LIVE_TEST_REPORT_DIR=reports/live-tests
# Optional backend smoke-readiness (dry-run only — does not call the endpoint)
# LIVE_TEST_BACKEND_BASE_URL=http://localhost:3004
# LIVE_TEST_BACKEND_TRIGGER_PATH=/invoice-processes/bitrix-trigger
# LIVE_TEST_BACKEND_AUTH_HEADER_NAME=x-api-key
# Optional override; if unset, live tests use N8N_API_KEY (same as N8nApiKeyGuard on backend)
# LIVE_TEST_BACKEND_AUTH_SECRET=replace-with-local-dummy-secret
# LIVE_TEST_BACKEND_HEALTH_PATH=/health
# LIVE_TEST_BACKEND_REQUEST_TIMEOUT_MS=5000
# Optional live smoke target (preflight only — does not call POST /invoice-processes/bitrix-trigger)
# LIVE_TEST_ACTUAL_BITRIX_DEAL_ID=28392
# LIVE_TEST_DEAL_LABEL=[TEST] Runner FULL smoke test 001
# LIVE_TEST_MANUAL_CRM_PREPARATION_CONFIRMED=false
# LIVE_TEST_EXPECTED_TRIGGER_STAGE_ID=PREPARATION
# Controlled Bitrix E2E setup (mode B: Bitrix/n8n triggers backend — runner does NOT POST bitrix-trigger)
# LIVE_TEST_ALLOW_BITRIX_TEST_DEAL_CREATION=false
# LIVE_TEST_ALLOW_BITRIX_STAGE_CHANGE=false
# Adds crm.address.list on existing company when missing (required for CRM_ADDRESS_LIST buyer validation)
# LIVE_TEST_ALLOW_BITRIX_COMPANY_ADDRESS_ENSURE=false
# LIVE_TEST_BITRIX_COMPANY_STREET=ul. Testowa 1
# LIVE_TEST_BITRIX_COMPANY_POSTAL_CODE=00-001
# LIVE_TEST_BITRIX_COMPANY_CITY=Warszawa
# LIVE_TEST_BITRIX_COMPANY_COUNTRY=PL
# Valid Polish NIP required for Fakturownia ADVANCE/FINAL (FULL is less strict)
# LIVE_TEST_BITRIX_COMPANY_NIP=5261040828
# Matrix live E2E: 45 runner-pass cases, one Bitrix deal per sequential invocation (see npm run live-test:matrix:live-e2e)
# LIVE_TEST_ALLOW_MATRIX_LIVE_E2E=false
# Option B: runner POSTs /invoice-processes/bitrix-trigger after Bitrix setup (requires LIVE_TEST_BACKEND_* + N8N_API_KEY)
# LIVE_TEST_ALLOW_MATRIX_BACKEND_TRIGGER=false
# LIVE_TEST_MATRIX_LIVE_E2E_DELAY_MS=3500
# LIVE_TEST_BITRIX_PAID_STAGE_ID=PREPARATION
# LIVE_TEST_BITRIX_INITIAL_STAGE_ID=UC_NEW
# Existing [TEST] company in Bitrix with NIP + requisites + address (required for E2E setup)
# LIVE_TEST_BITRIX_EXISTING_COMPANY_ID=replace-with-test-company-id
# LIVE_TEST_BITRIX_WEBHOOK_URL=
# LIVE_TEST_BITRIX_BASE_URL=https://evapremium.bitrix24.pl
# LIVE_TEST_BITRIX_AUTH_SECRET=
