NODE_ENV=development
PORT=3000
# Supabase PROD (kmepxyervpeujwvgdqtm) — password from Dashboard → Settings → Database (URL-encode special chars)
DATABASE_URL=postgresql://postgres:REPLACE_WITH_SUPABASE_DB_PASSWORD@db.kmepxyervpeujwvgdqtm.supabase.co:5432/postgres
DATABASE_SCHEMA=fakturownia-ksef-invoices
N8N_API_KEY=replace-with-n8n-to-backend-secret
ADMIN_API_KEY=replace-with-admin-secret
PANEL_API_KEY=replace-with-panel-secret
PANEL_ORIGIN=http://localhost:3000
BITRIX24_WEBHOOK_URL=https://evapremium.bitrix24.pl/rest/1/replace-with-webhook-token/
BITRIX24_PORTAL_URL=https://evapremium.bitrix24.pl/
FAKTUROWNIA_BASE_URL=https://example.fakturownia.pl/
FAKTUROWNIA_API_TOKEN=replace-with-fakturownia-token
FAKTUROWNIA_REQUEST_TIMEOUT_MS=30000

# Live tests (manual/ops only — never enable in production without explicit intent)
LIVE_TEST_MODE=false
LIVE_TEST_CONFIRM=false
ENABLE_EXTERNAL_SIDE_EFFECTS=false
ALLOW_TEST_DEAL_CREATION=false
TEST_DEAL_PREFIX=[TEST]
ALLOW_BULK_LIVE_TESTS=false
ALLOW_DELETE_OR_CANCEL=false
# Controlled single POST to /invoice-processes/bitrix-trigger (default blocked)
LIVE_TEST_ALLOW_BACKEND_TRIGGER_EXECUTION=false
# LIVE_TEST_REPORT_DIR=reports/live-tests
# Optional backend smoke-readiness (dry-run only — does not call the endpoint)
# LIVE_TEST_BACKEND_BASE_URL=http://localhost:3000
# LIVE_TEST_BACKEND_TRIGGER_PATH=/invoice-processes/bitrix-trigger
# LIVE_TEST_BACKEND_AUTH_HEADER_NAME=x-api-key
# LIVE_TEST_BACKEND_AUTH_SECRET=replace-with-local-dummy-secret
# LIVE_TEST_BACKEND_HEALTH_PATH=/health
# LIVE_TEST_BACKEND_REQUEST_TIMEOUT_MS=5000
# Optional live smoke target (preflight only — does not call POST /invoice-processes/bitrix-trigger)
# LIVE_TEST_ACTUAL_BITRIX_DEAL_ID=28392
# LIVE_TEST_DEAL_LABEL=[TEST] Runner FULL smoke test 001
# LIVE_TEST_MANUAL_CRM_PREPARATION_CONFIRMED=false
# LIVE_TEST_EXPECTED_TRIGGER_STAGE_ID=PREPARATION
