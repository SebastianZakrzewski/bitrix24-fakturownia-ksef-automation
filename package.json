{
  "name": "sellgenius-postsale-agent-v1",
  "version": "1.0.0",
  "description": "SellGenius V1 invoice automation backend skeleton.",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --config jest.config.ts --runInBand --testPathIgnorePatterns=\\.integration\\.spec\\.ts$",
    "test:integration": "jest --config jest.config.ts --runInBand --testPathPatterns=\\.integration\\.spec\\.ts$",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "db:migrate": "ts-node -r tsconfig-paths/register scripts/db-migrate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "pg": "^8.16.3",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.0.3",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-loader": "^9.5.7",
    "testcontainers": "^11.0.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
